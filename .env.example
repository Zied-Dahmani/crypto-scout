# ============================================================
# CRYPTO SCOUT — Environment Configuration
# Copy this file to .env and fill in your values.
# All keys are optional — missing ones fall back to mock data.
# ============================================================

# ── Discord (required for alerts) ──────────────────────────
# Channel settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── TikTok (recommended) ───────────────────────────────────
# Browser DevTools → tiktok.com cookies → copy msToken value
# Auto-refreshed by Playwright on every run.
TIKTOK_MS_TOKEN=

# ── Twitter scraper (free — no paid API needed) ────────────
# Any regular Twitter account. twscrape handles the rest.
TWITTER_SCRAPER_USERNAME=
TWITTER_SCRAPER_PASSWORD=
TWITTER_SCRAPER_EMAIL=

# ── Etherscan (free tier — ethereum wallet analysis) ───────
# etherscan.io → sign in → API Keys → Add
ETHERSCAN_API_KEY=

# ── Solscan (optional — solana wallet analysis) ────────────
# pro.solscan.io → API Key (free tier available)
# Works without a key at lower rate limits.
SOLSCAN_API_KEY=

# ── CoinGecko (optional — free tier works without key) ─────
# coingecko.com → Developers → API
COINGECKO_API_KEY=

# ── LLM (optional — not used in current pipeline) ──────────
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
