# ============================================================
# CRYPTO SCOUT — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Discord (required for alerts) ──────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Etherscan (free — ethereum wallet analysis) ────────────
# etherscan.io → sign in → API Keys → Add
ETHERSCAN_API_KEY=

# ── Solscan (optional — solana wallet analysis) ────────────
SOLSCAN_API_KEY=

# ── CoinGecko (optional) ───────────────────────────────────
COINGECKO_API_KEY=

# ── LLM (optional — not used in current pipeline) ──────────
# GROQ_API_KEY=gsk_...
