# ============================================
# CRYPTO SCOUT - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# ============================================
# LLM CONFIGURATION (Required - choose one)
# ============================================

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview

# OR Anthropic API
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# LLM_PROVIDER=anthropic

# ============================================
# SOCIAL MEDIA APIs (Optional but recommended)
# ============================================

# Twitter/X API v2
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# Reddit API
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=crypto-scout/1.0

# ============================================
# CRYPTO DATA API (Optional)
# ============================================

# CoinGecko (free tier works, pro for higher limits)
COINGECKO_API_KEY=your-coingecko-api-key

# ============================================
# NOTIFICATIONS (Choose one)
# ============================================

# Telegram Bot
NOTIFICATION_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# OR WhatsApp via Twilio
# NOTIFICATION_PROVIDER=whatsapp
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_WHATSAPP_FROM=+14155238886
# TWILIO_WHATSAPP_TO=+1234567890
