# ============================================
# CRYPTO SCOUT - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# ============================================
# LLM CONFIGURATION (Required - choose one)
# ============================================

# Groq API (Recommended - fast and free)
GROQ_API_KEY=gsk_your-groq-api-key-here

# OR OpenAI API
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OR Anthropic API
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OR Google Gemini API
# GOOGLE_API_KEY=your-google-api-key-here

# ============================================
# CRYPTO DATA API (Optional)
# ============================================

# CoinGecko (free tier works, pro for higher limits)
COINGECKO_API_KEY=your-coingecko-api-key

# ============================================
# NOTIFICATIONS - WhatsApp via Twilio (Optional)
# ============================================

# WhatsApp notifications via Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=+1234567890

# ============================================
# NOTE: Twitter uses mock data by default
# (No API keys required - cost optimized)
# ============================================
