# ============================================================
# CRYPTO SCOUT — Environment Configuration
# Copy this file to .env and fill in your keys.
# ============================================================

# ── LLM (choose one — Groq is free and fastest) ────────────
GROQ_API_KEY=gsk_your-groq-api-key-here
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GOOGLE_API_KEY=your-google-key

# ── CoinGecko (optional — free tier works without a key) ───
# COINGECKO_API_KEY=your-coingecko-pro-key

# ── Twitter / X API (optional) ─────────────────────────────
# Free account at developer.twitter.com -> Create App -> Bearer Token
# Without this, Twitter mentions fall back to mock data.
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ── Etherscan (optional) ───────────────────────────────────
# Free account at etherscan.io -> API Keys -> Create new key
# Without this, wallet analysis falls back to mock data.
# Only used for Ethereum ERC-20 tokens.
ETHERSCAN_API_KEY=your-etherscan-api-key
