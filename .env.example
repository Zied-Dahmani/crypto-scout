# ============================================
# CRYPTO SCOUT - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# ============================================
# LLM CONFIGURATION (Required - choose one)
# ============================================

# Groq API (Recommended - fast and FREE!)
GROQ_API_KEY=gsk_your-groq-api-key-here

# OR OpenAI API
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OR Anthropic API
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OR Google Gemini API
# GOOGLE_API_KEY=your-google-api-key-here

# ============================================
# CRYPTO DATA API (Optional)
# ============================================

# CoinGecko (free tier works, pro for higher limits)
# COINGECKO_API_KEY=your-coingecko-api-key

# ============================================
# NOTIFICATIONS - WhatsApp via Twilio (Optional)
# ============================================

# Get credentials from https://console.twilio.com
# 1. Sign up for free account ($15 trial credit)
# 2. Go to Messaging > Try it out > WhatsApp Sandbox
# 3. Join the sandbox by sending WhatsApp message to the number
# 4. Copy your credentials below

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=+1234567890

# ============================================
# NOTES
# ============================================
# - Twitter uses mock data (no API keys needed)
# - CoinGecko works without API key (rate limited)
# - WhatsApp is optional (logs to console if not configured)
